{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DepartmentState",
  "type": "object",
  "required": [
    "department",
    "biz_key",
    "state",
    "updated_at",
    "trace"
  ],
  "properties": {
    "department": { "type": "string", "minLength": 2 },
    "biz_key": { "type": "string", "minLength": 3 },
    "state": { "type": "string", "minLength": 2 },
    "updated_at": { "type": "string", "format": "date-time" },
    "trace": {
      "type": "object",
      "required": ["orchestrator_task_id", "batch_id", "run_id"],
      "properties": {
        "orchestrator_task_id": { "type": "string" },
        "batch_id": { "type": "string" },
        "run_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
